# ─────────────────────────────────────────────────────────────────
# CARPCONNECT MVP — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────

# --- Deployment ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/carpconnect

# --- Authentication ---
JWT_SECRET=super_secret_jwt_key_please_change_this_for_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=super_secret_refresh_key_please_change_this

# --- Maps / Routing (Choose one) ---
MAPBOX_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PLATFORM_FEE_PERCENT=10

# --- Redis (Optional caching) ---
REDIS_URL=redis://localhost:6379

# --- Communications (Optional for MVP local dev) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

SENDGRID_API_KEY=
EMAIL_FROM=no-reply@carpconnect.com

SENTRY_DSN=
